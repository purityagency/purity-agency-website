<!-- ═══ SERVICES — full-screen snap scenes ═══ -->
<section id="services" class="svc">
  <!-- Compteur de progression -->
  <div class="svc__progress" aria-hidden="true">
    <span class="svc__index">01</span>
    <span class="svc__bar"><i></i></span>
    <span class="svc__total">04</span>
  </div>

  <div class="svc__stage">
  <!-- Scène 1 — zone libre : DROITE (mur sombre) -->
  <article class="svc-scene is-active" data-scene="01" data-pos="right" style="--img:url('service1.webp')">
    <div class="svc-scene__media"></div>
    <div class="svc-scene__content">
      <span class="svc-scene__num">01</span>
      <h2 class="svc-scene__title">On vous rend <em>visible.</em></h2>
      <p class="svc-scene__lead">Quand un client tape votre métier dans Google, c'est vous qu'il doit trouver — pas le concurrent d'à côté. On construit une présence qui inspire confiance dès la première seconde.</p>
      <div class="svc-scene__tags"><span>Présence Google</span><span>Landing page</span><span>Site vitrine &amp; complet</span><span>E-commerce</span></div>
      <a class="svc-scene__more" href="presence.html">Voir en détail<span class="viz-arrow-line"></span></a>
    </div>
  </article>

  <!-- Scène 2 — zone libre : BAS-GAUCHE (table sombre) -->
  <article class="svc-scene" data-scene="02" data-pos="bottom-left" style="--img:url('service2.webp')">
    <div class="svc-scene__media"></div>
    <div class="svc-scene__content">
      <span class="svc-scene__num">02</span>
      <h2 class="svc-scene__title">On vous amène des <em>clients.</em></h2>
      <p class="svc-scene__lead">Être en ligne ne suffit pas si personne ne vous voit. On va chercher les clients là où ils sont déjà — et on les ramène vers vous, prêts à acheter.</p>
      <div class="svc-scene__tags"><span>SEO local</span><span>Google &amp; Meta Ads</span><span>E-mail &amp; SMS marketing</span></div>
      <a class="svc-scene__more" href="acquisition.html">Voir en détail<span class="viz-arrow-line"></span></a>
    </div>
  </article>

  <!-- Scène 3 — zone libre : DROITE (ciel/mer clairs ' texte sombre) -->
  <article class="svc-scene svc-scene--onlight" data-scene="03" data-pos="right" style="--img:url('service3.webp')">
    <div class="svc-scene__media"></div>
    <div class="svc-scene__content">
      <span class="svc-scene__num">03</span>
      <h2 class="svc-scene__title">On vous fait gagner du <em>temps.</em></h2>
      <p class="svc-scene__lead">Vous ne pouvez pas répondre à un message à 22h, ni en plein chantier. L'IA le fait pour vous : elle répond, prend les RDV, envoie les devis. Vous gardez le contrôle, pas la charge.</p>
      <div class="svc-scene__tags"><span>WhatsApp &amp; DM automatisés</span><span>Prise de RDV</span><span>Devis &amp; relances</span></div>
      <a class="svc-scene__more" href="automatisation.html">Voir en détail<span class="viz-arrow-line"></span></a>
    </div>
  </article>

  <!-- Scène 4 — zone libre : HAUT-DROITE (ciel clair ' texte sombre) -->
  <article class="svc-scene svc-scene--onlight" data-scene="04" data-pos="top-right" style="--img:url('service4.webp')">
    <div class="svc-scene__media"></div>
    <div class="svc-scene__content">
      <span class="svc-scene__num">04</span>
      <h2 class="svc-scene__title">On structure votre <em>activité.</em></h2>
      <p class="svc-scene__lead">Tout est dans votre tête, vos carnets, un Excel qui déborde. On rassemble votre activité dans un seul outil clair, fait pour vous : planning, clients, suivi — tout au même endroit.</p>
      <div class="svc-scene__tags"><span>Applications métier</span><span>Outils custom</span><span>Intégrations</span></div>
      <a class="svc-scene__more" href="outils.html">Voir en détail<span class="viz-arrow-line"></span></a>
    </div>
  </article>
  </div><!-- /.svc__stage -->
</section>

<hr class="sec-divider" aria-hidden="true">

<!-- ═══ STATS BENTO ═══ -->
<section class="sec sec--stats">
  <div class="bg-glow bg-glow--1" aria-hidden="true"></div>
  <div class="bg-glow bg-glow--2" aria-hidden="true"></div>
  <div class="wrap">
    <div class="bento2">

      <!-- 390 € — grande carte avec jauge -->
      <article class="b2 b2--price" data-reveal>
        <span class="b2__top">À partir de</span>
        <div class="b2__num"><span class="b2__count" data-count="390">0</span><small>€</small></div>
        <span class="b2__label">Votre première présence en ligne. Sans devis opaque.</span>
        <div class="b2__gauge"><span class="b2__gauge-fill"></span></div>
        <div class="b2__gauge-legend"><span>390 €</span><span>3 800 €+</span></div>
      </article>

      <!-- 24 h — horloge -->
      <article class="b2 b2--clock" data-reveal style="--d:.08s">
        <div class="b2__clock" aria-hidden="true">
          <span class="b2__hand b2__hand--h"></span>
          <span class="b2__hand b2__hand--m"></span>
          <span class="b2__dot"></span>
        </div>
        <div class="b2__num"><span class="b2__count" data-count="24">0</span><small>h</small></div>
        <span class="b2__label">Réponse garantie. Toujours.</span>
      </article>

      <!-- 0 € — gratuit -->
      <article class="b2 b2--free" data-reveal style="--d:.16s">
        <span class="b2__badge">Offert</span>
        <div class="b2__num"><span class="b2__count" data-count="0">0</span><small>€</small></div>
        <span class="b2__label">Le premier échange. Sans engagement.</span>
      </article>

      <!-- 4× — segments paiement -->
      <article class="b2 b2--split" data-reveal style="--d:.24s">
        <div class="b2__segs" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
        <div class="b2__num"><span class="b2__count" data-count="4">0</span><small>×</small></div>
        <span class="b2__label">Paiement en plusieurs fois.</span>
      </article>

    </div>
  </div>
</section>

<!-- ═══ POURQUOI PURITY — sticky split scroll-driven ═══ -->
<section id="pourquoi" class="why2">
  <div class="bg-glow bg-glow--1" aria-hidden="true"></div>
  <div class="why2__wrap">
    <div class="why2__sticky">
      <span class="tag lg">Pourquoi Purity</span>
      <h2 class="why2__title">La rigueur d'une agence.<br>Les prix d'un indé.<br><em>Obsession du résultat.</em></h2>
      <div class="why2__count"><span class="why2__count-now">01</span><span class="why2__count-tot">/03</span></div>
    </div>
    <div class="why2__list">
      <article class="why2__item" data-why="01">
        <span class="why2__big" aria-hidden="true">01</span>
        <div class="why2__viz why2__mini viz" aria-hidden="true">
          <div class="viz-bub">Vous êtes ouverts samedi ?</div>
          <div class="viz-bub viz-bub--me">Oui ! Je vous réserve 10 h ?</div>
          <div class="why2__mini-up"><span class="viz-live"></span>Répond seule, 24/7</div>
        </div>
        <div class="why2__body">
          <h3>La technologie effacée, <em>l'impact maximisé.</em></h3>
          <p>Ne vous souciez ni du code, ni de l'IA. Vous êtes là pour gagner 10h par semaine et décrocher des contrats. La machine tourne en silence, vous récoltez les fruits.</p>
        </div>
      </article>
      <article class="why2__item" data-why="02">
        <span class="why2__big" aria-hidden="true">02</span>
        <div class="why2__viz why2__mini viz" aria-hidden="true">
          <div class="viz-bars"><i style="--h:30"></i><i style="--h:45"></i><i style="--h:40"></i><i style="--h:62"></i><i style="--h:80"></i></div>
          <div class="why2__mini-up">↗ +47 % de demandes</div>
        </div>
        <div class="why2__body">
          <h3>Des actes, <em>pas du vocabulaire.</em></h3>
          <p>Le web est infesté de jargon pour justifier des factures salées. Chez nous : des prix publics, un langage direct, et un problème réglé en quelques jours, pas en trois mois.</p>
        </div>
      </article>
      <article class="why2__item" data-why="03">
        <span class="why2__big" aria-hidden="true">03</span>
        <div class="why2__viz why2__mini viz" aria-hidden="true">
          <div class="why2__mini-dots"><i></i><i></i><i></i></div>
          <div class="viz-line viz-line--hero"></div>
          <div class="viz-line viz-line--md"></div>
          <span class="viz-cta">Sur-mesure</span>
        </div>
        <div class="why2__body">
          <h3>Le design comme <em>avantage déloyal.</em></h3>
          <p>On refuse le template générique. À l'écran, votre activité doit immédiatement inspirer confiance, transpirer le haut de gamme, et éclipser la concurrence locale.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<hr class="sec-divider" aria-hidden="true">

<!-- ═══ MÉTHODE — scrollytelling pictos ═══ -->
<section id="methode" class="method">
  <div class="bg-glow bg-glow--1" aria-hidden="true"></div>
  <div class="wrap">
    <div class="sec-head" data-reveal>
      <span class="tag lg">Notre méthode</span>
      <h2>Simple pour vous.<br><em>Carré chez nous.</em></h2>
    </div>
    <div class="mtrack">
      <div class="mtrack__line" aria-hidden="true"><span class="mtrack__progress"></span></div>

      <article class="mstep" data-step="01">
        <span class="mstep__n">01</span>
        <div class="mstep__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-orb"></i></div>
        </div>
        <h3>On écoute</h3>
        <p>Votre vrai problème, pas un catalogue.</p>
      </article>

      <article class="mstep" data-step="02">
        <span class="mstep__n">02</span>
        <div class="mstep__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-geometric-line"></i></div>
        </div>
        <h3>On propose</h3>
        <p>Un plan clair, un prix clair.</p>
      </article>

      <article class="mstep" data-step="03">
        <span class="mstep__n">03</span>
        <div class="mstep__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-geometric-cross"></i></div>
        </div>
        <h3>On construit</h3>
        <p>Vite, bien. Vous suivez sans gérer.</p>
      </article>

      <article class="mstep" data-step="04">
        <span class="mstep__n">04</span>
        <div class="mstep__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-orb viz-orb--accent"></i></div>
        </div>
        <h3>On accompagne</h3>
        <p>On reste là. Ça continue de tourner.</p>
      </article>
    </div>
  </div>
</section>

<hr class="sec-divider" aria-hidden="true">

<!-- ═══ PREUVE / ENGAGEMENTS ═══ -->
<section id="preuve" class="sec sec--tentacles">
  <div class="wrap">
    <div class="sec-head" data-reveal>
      <span class="tag lg">Nos engagements</span>
      <h2>Ce sur quoi vous pouvez <em>compter.</em></h2>
      <p class="sec-head__lead">Pas de promesses en l'air. Des engagements simples, qu'on tient sur chaque projet.</p>
    </div>
    <div class="promise-cards" data-reveal>
      <div class="promise-card"><span class="promise-card__orb" aria-hidden="true"></span><span class="promise-card__big">0 €</span><h3>Premier échange</h3><p>Gratuit et sans engagement. On regarde votre situation, vous repartez avec des réponses.</p></div>
      <div class="promise-card"><span class="promise-card__orb" aria-hidden="true"></span><span class="promise-card__big">100 %</span><h3>Prix annoncé d'avance</h3><p>Le montant est fixé avant de commencer. Jamais de surprise en fin de projet.</p></div>
      <div class="promise-card"><span class="promise-card__orb" aria-hidden="true"></span><span class="promise-card__big">★★★</span><h3>Premium, ou on recommence</h3><p>Si le rendu ne fait pas premium, on retravaille. C'est notre nom qui est dessus.</p></div>
      <div class="promise-card"><span class="promise-card__orb" aria-hidden="true"></span><span class="promise-card__big">1</span><h3>Interlocuteur unique</h3><p>Une seule personne suit votre projet, joignable, qui connaît votre dossier par cœur.</p></div>
    </div>
  </div>
        <div class="field"><input type="text" id="f-name" name="name" placeholder=" " required autocomplete="name"><label for="f-name">Nom</label></div>
        <div class="field"><input type="email" id="f-email" name="email" placeholder=" " required autocomplete="email"><label for="f-email">E-mail</label></div>
        <div class="field"><input type="tel" id="f-phone" name="phone" placeholder=" " autocomplete="tel"><label for="f-phone">Téléphone <small>(facultatif)</small></label></div>
        <div class="field"><input type="text" id="f-activity" name="activity" placeholder=" "><label for="f-activity">Votre métier / activité</label></div>
        <div class="field"><textarea id="f-need" name="need" rows="4" placeholder=" " required></textarea><label for="f-need">Votre besoin en quelques mots</label></div>
        <div class="field" style="display:none!important" aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off"></div>
        <button type="submit" class="btn btn--white">Envoyer</button>
        <span class="form__note">Réponse garantie sous 24 h ouvrées.</span>
        <div class="form__sent"><strong>Message envoyé !</strong><span>On revient vers vous très vite.</span></div>
      </form>
    </div>
  </div>
</section>

</main>

