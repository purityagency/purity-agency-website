<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js"></script>
<script src="site.js" defer></script>

<!-- Bandeau cookies minimal (RGPD) -->
<div id="cookie-banner" class="cookie-banner" hidden>
  <p>Ce site utilise des polices externes (Google Fonts) et des librairies (Cloudflare CDN). Aucun cookie publicitaire n'est déposé. <a href="legal.html#cookies">En savoir plus</a></p>
  <button id="cookie-accept" class="btn btn--accent" style="padding:.6rem 1.4rem;font-size:.85rem">Compris</button>
</div>
<script>
(function(){
  if(localStorage.getItem('cookies_ok'))return;
  var b=document.getElementById('cookie-banner');
  if(b){b.removeAttribute('hidden');}
  var a=document.getElementById('cookie-accept');
  if(a)a.addEventListener('click',function(){localStorage.setItem('cookies_ok','1');b.setAttribute('hidden','');});
})();
</script>
</body>
