<!-- ═══ CE QU'ON FAIT POUR VOUS — 4 cards ═══ -->
<section id="probleme" class="sec svc-cards sec--tentacles">
  <div class="wrap">
    <h2 class="svc-cards__title" data-reveal>Ce qu'on fait pour vous</h2>
    <div class="svc-cards__grid">

      <article class="svc-card" data-reveal>
        <div class="svc-card__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-orb viz-orb--accent"></i></div>
        </div>
        <h3>Sites web performants</h3>
        <p>Des sites rapides, modernes et optimisés pour convertir vos visiteurs en clients.</p>
      </article>

      <article class="svc-card" data-reveal style="--d:.08s">
        <div class="svc-card__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-geometric-cross" style="color:var(--c-accent)"></i></div>
        </div>
        <h3>Présence Google Business</h3>
        <p>Soyez visible localement, remontez dans les résultats et attirez des clients près de chez vous.</p>
      </article>

      <article class="svc-card" data-reveal style="--d:.16s">
        <div class="svc-card__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-orb viz-orb--ok"></i></div>
        </div>
        <h3>Intégration WhatsApp</h3>
        <p>Discutez avec vos clients instantanément et ne ratez plus aucune opportunité.</p>
      </article>

      <article class="svc-card" data-reveal style="--d:.24s">
        <div class="svc-card__ico" aria-hidden="true">
          <div class="viz-glass-node"><i class="viz-geometric-line" style="color:var(--c-accent)"></i></div>
        </div>
        <h3>Automatisations &amp; IA</h3>
        <p>Gagnez du temps, automatisez vos tâches et concentrez-vous sur l'essentiel.</p>
      </article>

    </div>
  </div>
</section>

