<!-- Chatbot OctoMask -->
<div id="chat" class="chat">
  <div id="chat-teaser" class="chat__teaser" hidden>
    <button class="chat__teaser-close" aria-label="Fermer">✕</button>
    <span class="chat__teaser-wave">👋</span>
    <p>Un projet en tête ?<br><strong>Parlons-en — c'est gratuit.</strong></p>
  </div>
  <button id="chat-toggle" class="chat__toggle" aria-label="Ouvrir le chat">
    <video class="chat__avatar" data-src="octomask-floating.mp4" preload="none" muted loop autoplay playsinline disablepictureinpicture></video>
    <span class="chat-close">✕.</span>
  </button>
  <div id="chat-panel" class="chat__panel" role="dialog" aria-label="Assistant Purity" hidden>
    <div class="chat__header">
      <div class="chat__title">OctoMask IA</div>
      <div class="chat__status">En ligne</div>
    </div>
    <div id="chat-log" class="chat__log"></div>
    <form id="chat-form" class="chat__form">
      <input type="text" id="chat-input" class="chat__input" placeholder="Posez votre question..." autocomplete="off">
      <button type="submit" id="chat-submit" class="chat__submit" aria-label="Envoyer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </button>
    </form>
  </div>
</div>

